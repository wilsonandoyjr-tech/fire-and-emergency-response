{
  "name": "fire-alert-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "build:client": "npm run build --workspace client",
    "build:server": "npm run build --workspace server",
    "start": "npm run start --workspace server",
    "check": "npm run check --workspace client && npm run check --workspace server",
    "format": "prettier --write .",
    "test": "npm run test --workspace client",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "prettier": "^3.6.2"
  },
  "pnpm": {
    "patchedDependencies": {
      "wouter@3.7.1": "server/patches/wouter@3.7.1.patch"
    },
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    }
  }
}
